generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Core Entities (per SDD Section 5) ──

model Contact {
  id               String   @id @default(cuid())
  rawName          String
  normalizedName   String
  editedName       String?
  email            String
  linkedinUrl      String?
  title            String?
  role             String?
  phone            String?
  location         String?
  companyId        String
  batchId          String
  consentStatus    String   @default("unknown") // unknown, opted_in, opted_out
  emailHealth      String   @default("unknown") // unknown, valid, risky, invalid
  emailHealthScore Int      @default(0)
  status           String   @default("imported") // imported, cleaned, duplicate, drafted, queued, sent, replied, bounced, suppressed, archived
  leadScore        Int      @default(0)
  isSuppressed     Boolean  @default(false)
  suppressionReason String?
  lastCheckedAt    DateTime?
  lastContactedAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batch    ImportBatch @relation(fields: [batchId], references: [id])
  drafts      Draft[]
  replies     Reply[]
  bounces     Bounce[]
  suppression Suppression?

  @@index([email])
  @@index([companyId])
  @@index([status])
  @@index([batchId])
  @@index([leadScore])
}

model Company {
  id              String   @id @default(cuid())
  rawName         String
  normalizedName  String
  domain          String?
  industry        String?
  sizeRange       String?
  location        String?
  website         String?
  internalSummary String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts      Contact[]
  researchCard  CompanyResearchCard?
  notes         CompanyNote[]

  @@index([domain])
  @@index([normalizedName])
  @@index([industry])
}

model ImportBatch {
  id            String   @id @default(cuid())
  fileName      String
  fileHash      String   @unique
  totalRows     Int      @default(0)
  acceptedRows  Int      @default(0)
  duplicateRows Int      @default(0)
  invalidRows   Int      @default(0)
  questionableRows Int   @default(0)
  status        String   @default("staged") // staged, processing, completed, archived
  mappingProfile String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts Contact[]

  @@index([status])
  @@index([createdAt])
}

model CompanyResearchCard {
  id              String   @id @default(cuid())
  companyId       String   @unique
  businessOverview    String?
  techLandscape       String?
  potentialChallenges String?
  possibleOpportunities String?
  relevantServices    String?
  keyDecisionMakers   String?
  internalNotes       String?
  lastResearchedAt    DateTime @updatedAt
  createdAt           DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model CompanyNote {
  id        String   @id @default(cuid())
  companyId String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ── Capability Library (per SDD Section 10) ──

model CapabilityAsset {
  id          String   @id @default(cuid())
  title       String
  summary     String
  category    String   // service_line, case_study, proof_point, objection_response, cta
  serviceLine String?
  targetIndustries String?
  targetRoles  String?
  problems    String?
  evidence    String?
  content     String?  // full text
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([serviceLine])
  @@index([isActive])
}

// ── Draft & Send (per SDD Sections 11-12) ──

model Draft {
  id                String   @id @default(cuid())
  contactId         String
  subject           String
  body              String
  cta               String?
  confidenceScore   Int?
  sourceSnippetsUsed String?
  assumptionFlags   String?
  reviewNotes       String?
  status            String   @default("pending_review") // pending_review, approved, rejected, sent
  rejectReason      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  queueItem SendQueue?

  @@index([contactId])
  @@index([status])
}

model SendQueue {
  id            String   @id @default(cuid())
  draftId       String   @unique
  scheduledAt   DateTime?
  sentAt        DateTime?
  status        String   @default("pending") // pending, scheduled, sent, failed, paused
  failureReason String?
  retryCount    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([scheduledAt])
}

// ── Feedback (per SDD Section 13) ──

model Reply {
  id           String   @id @default(cuid())
  contactId    String
  subject      String?
  body         String?
  category     String?  // positive, negative, out_of_office, unsubscribe, other
  receivedAt   DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([category])
}

model Bounce {
  id           String   @id @default(cuid())
  contactId    String
  bounceType   String?  // hard, soft
  reason       String?
  bouncedAt    DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

model Suppression {
  id            String   @id @default(cuid())
  contactId     String   @unique
  reason        String   // unsubscribe, bounce, manual, negative_reply
  createdAt     DateTime @default(now())
  removedAt     DateTime?
  removedBy     String?
  removalReason String?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([reason])
}

// ── Audit (per SDD Section 16) ──

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  details   String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}