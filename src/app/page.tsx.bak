'use client';

import { useState, useEffect, useCallback } from 'react';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Progress } from '@/components/ui/progress';
import { ScrollArea } from '@/components/ui/scroll-area';
import { Separator } from '@/components/ui/separator';
import { Toaster } from '@/components/ui/sonner';
import { toast } from 'sonner';
import {
  Upload, Users, Brain, FileText, Send, Archive, Search,
  ChevronRight, AlertCircle, CheckCircle2, Clock, Sparkles,
  Target, BarChart3, TrendingUp, Eye, XCircle, Zap,
  FileUp, Database, BookOpen, Mail, MailCheck, MailX,
  ArrowUpRight, Filter, RefreshCw, Star, Building2, Briefcase,
} from 'lucide-react';

// ── Types ──
interface Company { id: string; name: string; domain?: string; industry?: string; employeeSize?: string; country?: string; intelligenceScore?: number; status: string; }
interface Contact { id: string; companyId: string; name: string; email?: string; jobTitle?: string; roleBucket?: string; status: string; emailHealth?: string; emailHealthScore?: number; company?: Company; }
interface ResearchCard { id: string; companyId: string; company?: Company; businessOverview?: string; currentTechLandscape?: string; potentialChallenges?: string; possibleOpportunities?: string; relevantServices?: string; keyDecisionMakers?: string; nextAction?: string; confidenceScore?: number; }
interface Draft { id: string; contactId: string; contact?: Contact; subject: string; body: string; cta?: string; serviceAngle?: string; matchScore?: number; confidenceScore?: number; status: string; rejectReason?: string; }
interface CapabilityDoc { id: string; title: string; docType: string; description?: string; snippets?: Snippet[]; }
interface Snippet { id: string; documentId: string; snippetType: string; title: string; content: string; industries?: string; outcomes?: string; }
interface Sequence { id: string; name: string; description?: string; status: string; contactId?: string; companyId?: string; steps?: SequenceStep[]; }
interface SequenceStep { id: string; stepNumber: number; subject: string; status: string; sentAt?: string; openedAt?: string; repliedAt?: string; delayMinutes: number; }
interface ImportBatch { id: string; fileName: string; totalRows: number; acceptedRows: number; duplicateRows: number; invalidRows: number; status: string; createdAt: string; }
interface Stats { totalLeads: number; drafts: number; sent: number; companies: number; capabilities: number; }

// ── Pipeline stages for header ──
const PIPELINE_STAGES = [
  { key: 'import', label: 'Import', icon: Upload },
  { key: 'leads', label: 'Leads', icon: Users },
  { key: 'research', label: 'Research', icon: Brain },
  { key: 'drafts', label: 'Drafts', icon: FileText },
  { key: 'send', label: 'Send Queue', icon: Send },
  { key: 'library', label: 'Capability Library', icon: Archive },
];

const healthColor = (h?: string) => h === 'valid' ? 'text-emerald-400' : h === 'risky' ? 'text-amber-400' : 'text-zinc-500';
const roleColor = (r?: string) => r === 'decision-maker' ? 'bg-amber-500/20 text-amber-300 border-amber-500/30' : r === 'influencer' ? 'bg-sky-500/20 text-sky-300 border-sky-500/30' : r === 'champion' ? 'bg-emerald-500/20 text-emerald-300 border-emerald-500/30' : 'bg-zinc-500/20 text-zinc-400 border-zinc-500/30';
const statusBadge = (s: string) => {
  if (s === 'approved' || s === 'sent') return <Badge className="bg-emerald-500/20 text-emerald-300 border-emerald-500/30">{s}</Badge>;
  if (s === 'pending-review') return <Badge className="bg-amber-500/20 text-amber-300 border-amber-500/30">Pending Review</Badge>;
  if (s === 'rejected') return <Badge className="bg-red-500/20 text-red-300 border-red-500/30">{s}</Badge>;
  if (s === 'draft') return <Badge className="bg-zinc-500/20 text-zinc-400 border-zinc-500/30">Draft</Badge>;
  if (s === 'completed') return <Badge className="bg-emerald-500/20 text-emerald-300 border-emerald-500/30">Completed</Badge>;
  if (s === 'processing') return <Badge className="bg-blue-500/20 text-blue-300 border-blue-500/30">Processing</Badge>;
  if (s === 'active') return <Badge className="bg-amber-500/20 text-amber-300 border-amber-500/30">Active</Badge>;
  return <Badge className="bg-zinc-500/20 text-zinc-400 border-zinc-500/30">{s}</Badge>;
};
const scoreColor = (s?: number) => !s ? 'text-zinc-500' : s >= 85 ? 'text-emerald-400' : s >= 70 ? 'text-amber-400' : 'text-red-400';

export default function HomePage() {
  const [activeTab, setActiveTab] = useState('leads');
  const [stats, setStats] = useState<Stats | null>(null);
  const [leads, setLeads] = useState<Contact[]>([]);
  const [researchCards, setResearchCards] = useState<ResearchCard[]>([]);
  const [drafts, setDrafts] = useState<Draft[]>([]);
  const [capabilities, setCapabilities] = useState<CapabilityDoc[]>([]);
  const [sequences, setSequences] = useState<Sequence[]>([]);
  const [batches, setBatches] = useState<ImportBatch[]>([]);
  const [search, setSearch] = useState('');
  const [loading, setLoading] = useState(true);
  const [selectedDraft, setSelectedDraft] = useState<Draft | null>(null);

  const fetchData = useCallback(async () => {
    try {
      const [s, l, r, d, c, q] = await Promise.all([
        fetch('/api/stats').then(r => r.json()),
        fetch('/api/leads').then(r => r.json()),
        fetch('/api/research').then(r => r.json()),
        fetch('/api/drafts').then(r => r.json()),
        fetch('/api/capabilities').then(r => r.json()),
        fetch('/api/queue').then(r => r.json()),
      ]);
      setStats(s); setLeads(l); setResearchCards(r); setDrafts(d); setCapabilities(c); setSequences(q);
    } catch (e) { console.error(e); }
    finally { setLoading(false); }
  }, []);

  useEffect(() => { fetchData(); }, [fetchData]);

  const handleApproveDraft = async (draft: Draft) => {
    try {
      await fetch('/api/drafts', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: draft.id, status: 'approved' }) });
      toast.success('Draft approved and queued for sending');
      fetchData();
    } catch { toast.error('Failed to approve draft'); }
  };

  const handleRejectDraft = async (draft: Draft) => {
    try {
      await fetch('/api/drafts', { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: draft.id, status: 'rejected', rejectReason: 'Not personalized enough' }) });
      toast.success('Draft rejected');
      fetchData();
      setSelectedDraft(null);
    } catch { toast.error('Failed to reject draft'); }
  };

  const filteredLeads = leads.filter(l =>
    !search || l.name.toLowerCase().includes(search.toLowerCase()) ||
    l.email?.toLowerCase().includes(search.toLowerCase()) ||
    l.company?.name.toLowerCase().includes(search.toLowerCase()) ||
    l.jobTitle?.toLowerCase().includes(search.toLowerCase())
  );

  const filteredDrafts = drafts.filter(d =>
    !search || d.subject.toLowerCase().includes(search.toLowerCase()) ||
    d.contact?.name.toLowerCase().includes(search.toLowerCase()) ||
    d.serviceAngle?.toLowerCase().includes(search.toLowerCase())
  );

  if (loading) return (
    <div className="min-h-screen bg-zinc-950 flex items-center justify-center">
      <div className="flex flex-col items-center gap-4">
        <div className="w-12 h-12 border-2 border-amber-500 border-t-transparent rounded-full animate-spin" />
        <p className="text-zinc-400 text-sm">Loading DeepMindQ...</p>
      </div>
    </div>
  );

  return (
    <div className="min-h-screen bg-zinc-950 text-zinc-100">
      <Toaster theme="dark" position="top-right" />

      {/* ── Top Bar ── */}
      <header className="sticky top-0 z-50 bg-zinc-950/80 backdrop-blur-xl border-b border-zinc-800/60">
        <div className="max-w-[1600px] mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-8 h-8 rounded-lg bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center">
              <Sparkles className="w-4 h-4 text-zinc-900" />
            </div>
            <span className="font-semibold text-sm tracking-tight">DeepMindQ</span>
            <span className="hidden sm:inline text-[11px] text-zinc-500 border-l border-zinc-700 pl-3 ml-1">Lead Intelligence & AI Outreach</span>
          </div>
          <div className="flex items-center gap-3">
            <Button variant="ghost" size="sm" className="text-zinc-400 hover:text-zinc-100 h-8" onClick={fetchData}>
              <RefreshCw className="w-3.5 h-3.5 mr-1.5" /> Refresh
            </Button>
            <div className="w-8 h-8 rounded-full bg-amber-500/20 border border-amber-500/30 flex items-center justify-center text-amber-400 text-xs font-semibold">RS</div>
          </div>
        </div>
      </header>

      <main className="max-w-[1600px] mx-auto px-4 sm:px-6 py-6">
        {/* ── Stats Bar ── */}
        {stats && (
          <div className="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-3 mb-6">
            {[
              { label: 'Total Leads', value: stats.totalLeads, icon: Users, color: 'text-amber-400' },
              { label: 'Researched', value: researchCards.length, icon: Brain, color: 'text-sky-400' },
              { label: 'Drafts', value: stats.drafts, icon: FileText, color: 'text-violet-400' },
              { label: 'Sent', value: stats.sent, icon: MailCheck, color: 'text-emerald-400' },
              { label: 'Capabilities', value: stats.capabilities, icon: Archive, color: 'text-rose-400' },
            ].map(s => (
              <Card key={s.label} className="bg-zinc-900/50 border-zinc-800/60 hover:border-zinc-700/60 transition-colors">
                <CardContent className="p-3 sm:p-4">
                  <div className="flex items-center justify-between mb-1">
                    <span className="text-[11px] text-zinc-500 uppercase tracking-wider">{s.label}</span>
                    <s.icon className={`w-3.5 h-3.5 ${s.color} opacity-60`} />
                  </div>
                  <p className={`text-xl font-bold ${s.color}`}>{s.value}</p>
                </CardContent>
              </Card>
            ))}
          </div>
        )}

        {/* ── Pipeline Tabs ── */}
        <Tabs value={activeTab} onValueChange={setActiveTab}>
          <TabsList className="bg-zinc-900/50 border border-zinc-800/60 p-1 mb-6 h-auto flex-wrap gap-1">
            {PIPELINE_STAGES.map(stage => (
              <TabsTrigger
                key={stage.key}
                value={stage.key}
                className="data-[state=active]:bg-amber-500/15 data-[state=active]:text-amber-400 data-[state=active]:border-amber-500/30 data-[state=active]:shadow-none text-zinc-400 text-xs px-3 py-1.5 rounded-md gap-1.5"
              >
                <stage.icon className="w-3.5 h-3.5" />
                <span className="hidden sm:inline">{stage.label}</span>
              </TabsTrigger>
            ))}
          </TabsList>

          {/* ━━━━━━━━━━━━━━━━━━━ IMPORT TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="import">
            <Card className="bg-zinc-900/50 border-zinc-800/60">
              <CardHeader>
                <CardTitle className="text-base flex items-center gap-2"><Upload className="w-4 h-4 text-amber-400" /> Import Leads</CardTitle>
                <CardDescription>Upload CSV files with contact and company data. The system will clean, deduplicate, and score your leads.</CardDescription>
              </CardHeader>
              <CardContent className="space-y-6">
                <div className="border-2 border-dashed border-zinc-700/60 rounded-xl p-8 text-center hover:border-amber-500/40 transition-colors cursor-pointer" onClick={() => toast.info('File upload would open here in production')}>
                  <FileUp className="w-10 h-10 text-zinc-600 mx-auto mb-3" />
                  <p className="text-zinc-300 text-sm font-medium">Drop CSV files here or click to browse</p>
                  <p className="text-zinc-500 text-xs mt-1">Supports: Name, Email, Company, Title, LinkedIn URL</p>
                </div>

                <div>
                  <h3 className="text-sm font-medium text-zinc-300 mb-3">Recent Imports</h3>
                  <div className="space-y-2">
                    {batches.length === 0 && (
                      <div className="text-center py-8 text-zinc-500 text-sm">
                        <Database className="w-8 h-8 mx-auto mb-2 opacity-40" />
                        No imports yet. Upload a CSV to get started.
                      </div>
                    )}
                    {batches.map(b => (
                      <div key={b.id} className="flex items-center gap-4 p-3 rounded-lg bg-zinc-800/40 border border-zinc-700/40">
                        <div className="w-9 h-9 rounded-lg bg-zinc-800 flex items-center justify-center">
                          <FileUp className="w-4 h-4 text-zinc-400" />
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="text-sm font-medium truncate">{b.fileName}</p>
                          <p className="text-xs text-zinc-500">{new Date(b.createdAt).toLocaleDateString()} — {b.acceptedRows}/{b.totalRows} accepted, {b.duplicateRows} dupes, {b.invalidRows} invalid</p>
                        </div>
                        {statusBadge(b.status)}
                      </div>
                    ))}
                  </div>
                </div>
              </CardContent>
            </Card>
          </TabsContent>

          {/* ━━━━━━━━━━━━━━━━━━━ LEADS TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="leads">
            <Card className="bg-zinc-900/50 border-zinc-800/60">
              <CardHeader className="pb-3">
                <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <CardTitle className="text-base flex items-center gap-2"><Users className="w-4 h-4 text-amber-400" /> Lead List</CardTitle>
                    <CardDescription className="mt-1">Contacts scored and ready for research and outreach</CardDescription>
                  </div>
                  <div className="relative">
                    <Search className="w-3.5 h-3.5 text-zinc-500 absolute left-2.5 top-1/2 -translate-y-1/2" />
                    <Input placeholder="Search leads..." value={search} onChange={e => setSearch(e.target.value)} className="pl-8 h-8 bg-zinc-800/50 border-zinc-700/50 text-sm w-full sm:w-64" />
                  </div>
                </div>
              </CardHeader>
              <CardContent>
                <ScrollArea className="max-h-[600px]">
                  <div className="space-y-2">
                    {filteredLeads.map(lead => (
                      <div key={lead.id} className="flex items-center gap-4 p-3 rounded-lg bg-zinc-800/30 border border-zinc-700/30 hover:border-zinc-600/40 transition-colors">
                        <div className="w-9 h-9 rounded-full bg-amber-500/15 border border-amber-500/20 flex items-center justify-center text-amber-400 text-xs font-bold shrink-0">
                          {lead.name.split(' ').map(n => n[0]).join('')}
                        </div>
                        <div className="flex-1 min-w-0">
                          <div className="flex items-center gap-2 flex-wrap">
                            <p className="text-sm font-medium">{lead.name}</p>
                            {lead.roleBucket && <span className={`text-[10px] px-1.5 py-0.5 rounded border ${roleColor(lead.roleBucket)}`}>{lead.roleBucket}</span>}
                          </div>
                          <div className="flex items-center gap-2 text-xs text-zinc-500 mt-0.5">
                            <span>{lead.jobTitle}</span>
                            {lead.company && <><ChevronRight className="w-3 h-3" /><Building2 className="w-3 h-3" /><span>{lead.company.name}</span></>}
                          </div>
                          {lead.email && <p className={`text-xs mt-0.5 ${healthColor(lead.emailHealth)}`}>{lead.email} {lead.emailHealthScore && <span className="text-zinc-600">({lead.emailHealthScore})</span>}</p>}
                        </div>
                        <div className="text-right shrink-0">
                          {lead.company?.intelligenceScore ? (
                            <div className="flex flex-col items-end">
                              <span className={`text-lg font-bold ${scoreColor(lead.company.intelligenceScore)}`}>{lead.company.intelligenceScore}</span>
                              <span className="text-[10px] text-zinc-500">INT. SCORE</span>
                            </div>
                          ) : (
                            <span className="text-[10px] text-zinc-600 px-2">Not scored</span>
                          )}
                        </div>
                      </div>
                    ))}
                    {filteredLeads.length === 0 && (
                      <div className="text-center py-12 text-zinc-500 text-sm">
                        <Users className="w-8 h-8 mx-auto mb-2 opacity-40" />
                        {search ? 'No leads match your search' : 'No leads imported yet. Start by uploading a CSV.'}
                      </div>
                    )}
                  </div>
                </ScrollArea>
              </CardContent>
            </Card>
          </TabsContent>

          {/* ━━━━━━━━━━━━━━━━━━━ RESEARCH TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="research">
            <Card className="bg-zinc-900/50 border-zinc-800/60">
              <CardHeader className="pb-3">
                <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <CardTitle className="text-base flex items-center gap-2"><Brain className="w-4 h-4 text-sky-400" /> Company Intelligence</CardTitle>
                    <CardDescription className="mt-1">AI-researched company profiles with pain points, tech landscape, and opportunity mapping</CardDescription>
                  </div>
                  <Button size="sm" className="bg-sky-500/15 text-sky-400 border border-sky-500/30 hover:bg-sky-500/25 h-8 text-xs" onClick={() => toast.info('AI research would run on selected companies in production')}>
                    <Sparkles className="w-3.5 h-3.5 mr-1.5" /> Research New Company
                  </Button>
                </div>
              </CardHeader>
              <CardContent>
                <ScrollArea className="max-h-[700px]">
                  <div className="space-y-4">
                    {researchCards.map(rc => (
                      <div key={rc.id} className="rounded-xl bg-zinc-800/30 border border-zinc-700/30 p-4 hover:border-zinc-600/40 transition-colors">
                        <div className="flex items-start justify-between mb-3">
                          <div>
                            <h3 className="text-sm font-semibold flex items-center gap-2">
                              {rc.company?.name || 'Unknown Company'}
                              <Badge variant="outline" className="text-[10px] border-zinc-600 text-zinc-400">{rc.company?.industry}</Badge>
                            </h3>
                            {rc.company?.employeeSize && <p className="text-xs text-zinc-500 mt-0.5">{rc.company.employeeSize} employees · {rc.company.country}</p>}
                          </div>
                          <div className="text-right shrink-0">
                            <span className={`text-lg font-bold ${scoreColor(rc.confidenceScore)}`}>{rc.confidenceScore}%</span>
                            <p className="text-[10px] text-zinc-500">CONFIDENCE</p>
                          </div>
                        </div>

                        <div className="grid sm:grid-cols-2 gap-3 text-sm">
                          <div>
                            <p className="text-[10px] uppercase tracking-wider text-zinc-500 mb-1">Business Overview</p>
                            <p className="text-xs text-zinc-300 leading-relaxed">{rc.businessOverview}</p>
                          </div>
                          <div>
                            <p className="text-[10px] uppercase tracking-wider text-zinc-500 mb-1">Tech Landscape</p>
                            <p className="text-xs text-zinc-300 leading-relaxed">{rc.currentTechLandscape}</p>
                          </div>
                          <div>
                            <p className="text-[10px] uppercase tracking-wider text-zinc-500 mb-1">Challenges</p>
                            <p className="text-xs text-zinc-300 leading-relaxed">{rc.potentialChallenges}</p>
                          </div>
                          <div>
                            <p className="text-[10px] uppercase tracking-wider text-amber-400 mb-1">Opportunities</p>
                            <p className="text-xs text-zinc-300 leading-relaxed">{rc.possibleOpportunities}</p>
                          </div>
                        </div>

                        <Separator className="my-3 bg-zinc-700/40" />

                        <div className="flex flex-wrap gap-4 text-xs">
                          <div><span className="text-zinc-500">Services:</span> <span className="text-amber-400/80">{rc.relevantServices}</span></div>
                          <div><span className="text-zinc-500">Decision Makers:</span> <span className="text-zinc-300">{rc.keyDecisionMakers}</span></div>
                        </div>

                        {rc.nextAction && (
                          <div className="mt-3 p-2.5 rounded-lg bg-amber-500/5 border border-amber-500/15">
                            <p className="text-[10px] uppercase tracking-wider text-amber-400 mb-0.5">Next Action</p>
                            <p className="text-xs text-zinc-300">{rc.nextAction}</p>
                          </div>
                        )}
                      </div>
                    ))}
                    {researchCards.length === 0 && (
                      <div className="text-center py-12 text-zinc-500 text-sm">
                        <Brain className="w-8 h-8 mx-auto mb-2 opacity-40" />
                        No research cards yet. Select companies from the Leads tab to run AI research.
                      </div>
                    )}
                  </div>
                </ScrollArea>
              </CardContent>
            </Card>
          </TabsContent>

          {/* ━━━━━━━━━━━━━━━━━━━ DRAFTS TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="drafts">
            <div className="grid lg:grid-cols-5 gap-4">
              {/* Draft list */}
              <div className="lg:col-span-2">
                <Card className="bg-zinc-900/50 border-zinc-800/60">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-base flex items-center gap-2"><FileText className="w-4 h-4 text-violet-400" /> Draft Review</CardTitle>
                    <CardDescription>AI-generated emails using your Capability Library. Review before sending.</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <div className="relative mb-3">
                      <Search className="w-3.5 h-3.5 text-zinc-500 absolute left-2.5 top-1/2 -translate-y-1/2" />
                      <Input placeholder="Filter drafts..." value={search} onChange={e => setSearch(e.target.value)} className="pl-8 h-8 bg-zinc-800/50 border-zinc-700/50 text-sm" />
                    </div>
                    <ScrollArea className="max-h-[500px]">
                      <div className="space-y-2">
                        {filteredDrafts.map(d => (
                          <div
                            key={d.id}
                            onClick={() => setSelectedDraft(d)}
                            className={`p-3 rounded-lg cursor-pointer border transition-colors ${selectedDraft?.id === d.id ? 'bg-amber-500/10 border-amber-500/30' : 'bg-zinc-800/30 border-zinc-700/30 hover:border-zinc-600/40'}`}
                          >
                            <div className="flex items-start justify-between gap-2">
                              <p className="text-sm font-medium leading-tight line-clamp-1">{d.subject}</p>
                              {statusBadge(d.status)}
                            </div>
                            <div className="flex items-center gap-2 text-xs text-zinc-500 mt-1">
                              <span>{d.contact?.name}</span>
                              {d.contact?.company && <span>· {d.contact.company.name}</span>}
                            </div>
                            <div className="flex items-center gap-3 mt-2">
                              {d.matchScore && (
                                <div className="flex items-center gap-1">
                                  <Target className="w-3 h-3 text-amber-400" />
                                  <span className="text-[11px] text-amber-400">{d.matchScore}% match</span>
                                </div>
                              )}
                              {d.serviceAngle && (
                                <Badge variant="outline" className="text-[10px] border-zinc-600 text-zinc-400">{d.serviceAngle}</Badge>
                              )}
                            </div>
                          </div>
                        ))}
                        {filteredDrafts.length === 0 && (
                          <div className="text-center py-8 text-zinc-500 text-sm">
                            <FileText className="w-8 h-8 mx-auto mb-2 opacity-40" />
                            No drafts to review.
                          </div>
                        )}
                      </div>
                    </ScrollArea>
                  </CardContent>
                </Card>
              </div>

              {/* Draft detail */}
              <div className="lg:col-span-3">
                <Card className="bg-zinc-900/50 border-zinc-800/60">
                  <CardContent className="p-5">
                    {selectedDraft ? (
                      <div className="space-y-4">
                        <div className="flex items-start justify-between">
                          <div>
                            <h3 className="text-sm font-semibold">{selectedDraft.subject}</h3>
                            <p className="text-xs text-zinc-500 mt-0.5">To: {selectedDraft.contact?.name} ({selectedDraft.contact?.email}) · {selectedDraft.contact?.company?.name}</p>
                          </div>
                          <div className="flex gap-2">
                            {selectedDraft.matchScore && <div className="text-center"><span className={`text-lg font-bold ${scoreColor(selectedDraft.matchScore)}`}>{selectedDraft.matchScore}%</span><p className="text-[10px] text-zinc-500">MATCH</p></div>}
                            {selectedDraft.confidenceScore && <div className="text-center"><span className="text-lg font-bold text-sky-400">{selectedDraft.confidenceScore}%</span><p className="text-[10px] text-zinc-500">CONF.</p></div>}
                          </div>
                        </div>

                        <div className="flex gap-2">
                          {selectedDraft.serviceAngle && <Badge className="bg-amber-500/15 text-amber-300 border-amber-500/20">{selectedDraft.serviceAngle}</Badge>}
                          {statusBadge(selectedDraft.status)}
                        </div>

                        <Separator className="bg-zinc-700/40" />

                        <div className="bg-zinc-800/50 rounded-lg p-4 border border-zinc-700/30">
                          <p className="text-[10px] uppercase tracking-wider text-zinc-500 mb-2">Email Preview</p>
                          <div className="text-sm text-zinc-300 whitespace-pre-line leading-relaxed">{selectedDraft.body}</div>
                        </div>

                        {selectedDraft.cta && (
                          <div className="p-3 rounded-lg bg-emerald-500/5 border border-emerald-500/15">
                            <p className="text-[10px] uppercase tracking-wider text-emerald-400 mb-0.5">Call to Action</p>
                            <p className="text-xs text-zinc-300">{selectedDraft.cta}</p>
                          </div>
                        )}

                        {selectedDraft.rejectReason && (
                          <div className="p-3 rounded-lg bg-red-500/5 border border-red-500/15">
                            <p className="text-[10px] uppercase tracking-wider text-red-400 mb-0.5">Rejection Reason</p>
                            <p className="text-xs text-zinc-300">{selectedDraft.rejectReason}</p>
                          </div>
                        )}

                        {selectedDraft.status === 'pending-review' && (
                          <div className="flex gap-2 pt-2">
                            <Button className="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white h-9 text-sm" onClick={() => handleApproveDraft(selectedDraft)}>
                              <CheckCircle2 className="w-4 h-4 mr-1.5" /> Approve & Queue
                            </Button>
                            <Button variant="outline" className="flex-1 border-zinc-600 text-zinc-300 hover:bg-zinc-800 h-9 text-sm" onClick={() => handleRejectDraft(selectedDraft)}>
                              <XCircle className="w-4 h-4 mr-1.5" /> Reject
                            </Button>
                          </div>
                        )}
                      </div>
                    ) : (
                      <div className="flex flex-col items-center justify-center py-16 text-zinc-500">
                        <Mail className="w-10 h-10 mb-3 opacity-30" />
                        <p className="text-sm">Select a draft to preview and review</p>
                      </div>
                    )}
                  </CardContent>
                </Card>
              </div>
            </div>
          </TabsContent>

          {/* ━━━━━━━━━━━━━━━━━━━ SEND QUEUE TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="send">
            <Card className="bg-zinc-900/50 border-zinc-800/60">
              <CardHeader className="pb-3">
                <CardTitle className="text-base flex items-center gap-2"><Send className="w-4 h-4 text-emerald-400" /> Send Queue</CardTitle>
                <CardDescription>Email sequences: initial email + 2 follow-ups per contact. Sent via Outlook Graph API.</CardDescription>
              </CardHeader>
              <CardContent>
                <ScrollArea className="max-h-[600px]">
                  <div className="space-y-3">
                    {sequences.map(seq => (
                      <div key={seq.id} className="rounded-xl bg-zinc-800/30 border border-zinc-700/30 p-4">
                        <div className="flex items-center justify-between mb-3">
                          <div>
                            <h3 className="text-sm font-semibold">{seq.name}</h3>
                            {seq.description && <p className="text-xs text-zinc-500 mt-0.5">{seq.description}</p>}
                          </div>
                          {statusBadge(seq.status)}
                        </div>
                        <div className="space-y-2">
                          {seq.steps?.map(step => (
                            <div key={step.id} className="flex items-center gap-3 p-2.5 rounded-lg bg-zinc-900/40 border border-zinc-700/20">
                              <div className="w-7 h-7 rounded-full bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-400 shrink-0">{step.stepNumber}</div>
                              <div className="flex-1 min-w-0">
                                <p className="text-xs font-medium truncate">{step.subject}</p>
                                <p className="text-[10px] text-zinc-500">
                                  {step.delayMinutes === 0 ? 'Immediate' : `After ${step.delayMinutes / 1440} day${step.delayMinutes >= 2880 ? 's' : ''}`}
                                </p>
                              </div>
                              <div className="flex items-center gap-2 shrink-0">
                                {step.status === 'sent' && <><MailCheck className="w-4 h-4 text-emerald-400" /><span className="text-[10px] text-zinc-500">Sent</span></>}
                                {step.status === 'pending' && <><Clock className="w-4 h-4 text-zinc-500" /><span className="text-[10px] text-zinc-500">Queued</span></>}
                                {step.openedAt && <><Eye className="w-3.5 h-3.5 text-sky-400" /><span className="text-[10px] text-sky-400">Opened</span></>}
                                {step.repliedAt && <><Mail className="w-3.5 h-3.5 text-amber-400" /><span className="text-[10px] text-amber-400">Replied</span></>}
                              </div>
                            </div>
                          ))}
                        </div>
                      </div>
                    ))}
                    {sequences.length === 0 && (
                      <div className="text-center py-12 text-zinc-500 text-sm">
                        <Send className="w-8 h-8 mx-auto mb-2 opacity-40" />
                        No sequences queued. Approve drafts to create send sequences.
                      </div>
                    )}
                  </div>
                </ScrollArea>
              </CardContent>
            </Card>
          </TabsContent>

          {/* ━━━━━━━━━━━━━━━━━━━ CAPABILITY LIBRARY TAB ━━━━━━━━━━━━━━━━━━━ */}
          <TabsContent value="library">
            <Card className="bg-zinc-900/50 border-zinc-800/60">
              <CardHeader className="pb-3">
                <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                  <div>
                    <CardTitle className="text-base flex items-center gap-2"><Archive className="w-4 h-4 text-rose-400" /> Capability Library</CardTitle>
                    <CardDescription className="mt-1">Your internal knowledge base: services, proof points, case studies, and objection responses. This is what makes AI drafts personalized.</CardDescription>
                  </div>
                  <Button size="sm" className="bg-rose-500/15 text-rose-400 border border-rose-500/30 hover:bg-rose-500/25 h-8 text-xs" onClick={() => toast.info('Add capability form would open here in production')}>
                    <BookOpen className="w-3.5 h-3.5 mr-1.5" /> Add Asset
                  </Button>
                </div>
              </CardHeader>
              <CardContent>
                <ScrollArea className="max-h-[700px]">
                  <div className="space-y-4">
                    {capabilities.map(cap => (
                      <div key={cap.id} className="rounded-xl bg-zinc-800/30 border border-zinc-700/30 p-4 hover:border-zinc-600/40 transition-colors">
                        <div className="flex items-start justify-between mb-2">
                          <div>
                            <h3 className="text-sm font-semibold flex items-center gap-2">
                              {cap.title}
                              <Badge variant="outline" className="text-[10px] border-zinc-600 text-zinc-400">{cap.docType}</Badge>
                            </h3>
                            {cap.description && <p className="text-xs text-zinc-500 mt-0.5">{cap.description}</p>}
                          </div>
                          <BookOpen className="w-4 h-4 text-zinc-600 shrink-0" />
                        </div>

                        {cap.snippets && cap.snippets.length > 0 && (
                          <div className="mt-3 space-y-2">
                            {cap.snippets.map(sn => (
                              <div key={sn.id} className={`p-2.5 rounded-lg border ${sn.snippetType === 'proof-point' ? 'bg-emerald-500/5 border-emerald-500/15' : sn.snippetType === 'objection-response' ? 'bg-amber-500/5 border-amber-500/15' : 'bg-zinc-800/50 border-zinc-700/30'}`}>
                                <div className="flex items-center gap-2 mb-1">
                                  {sn.snippetType === 'proof-point' ? <Star className="w-3 h-3 text-emerald-400" /> : <Zap className="w-3 h-3 text-amber-400" />}
                                  <p className="text-xs font-medium">{sn.title}</p>
                                  {sn.industries && <span className="text-[10px] text-zinc-500 ml-auto">{sn.industries}</span>}
                                </div>
                                <p className="text-xs text-zinc-400 leading-relaxed">{sn.content}</p>
                                {sn.outcomes && <p className="text-[10px] text-emerald-400/70 mt-1">Outcome: {sn.outcomes}</p>}
                              </div>
                            ))}
                          </div>
                        )}
                      </div>
                    ))}
                    {capabilities.length === 0 && (
                      <div className="text-center py-12 text-zinc-500 text-sm">
                        <Archive className="w-8 h-8 mx-auto mb-2 opacity-40" />
                        No capabilities added yet. Build your library to power AI draft generation.
                      </div>
                    )}
                  </div>
                </ScrollArea>
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>
      </main>

      {/* Footer */}
      <footer className="border-t border-zinc-800/40 mt-12">
        <div className="max-w-[1600px] mx-auto px-4 sm:px-6 py-4 flex items-center justify-between text-[11px] text-zinc-600">
          <span>DeepMindQ — Lead Intelligence & AI-Powered Outreach</span>
          <span>NOT a CRM</span>
        </div>
      </footer>
    </div>
  );
}